<?xml version="1.0" encoding="utf-8"?>
<package>
  <metadata>
    <id>NetSquare.Server</id>
    <version>1.0.5</version>
    <title>NetSquare.Server</title>
    <authors>VRDTMStudio</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <icon>images\NetSquareIcon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/Keksls/NetSquare</projectUrl>
    <description>NetSquare as a verry fast and easy to use .NET Tcp/Udp solution for Server/client developpment. Unity compatible</description>
    <releaseNotes>SDK-style package with .NET Standard, .NET Core and .NET Framework builds.</releaseNotes>
    <copyright>Copyright © 2022</copyright>
    <tags>TCP UDP Server Client Network MMORPG URPG Unity</tags>
    <dependencies>
      <group targetFramework="netstandard2.0" />
      <group targetFramework="net8.0-windows7.0" />
      <group targetFramework="net48" />
    </dependencies>
  </metadata>
  <files>
    <file src="bin\Release\netstandard2.0\NetSquareCore.dll" target="lib\netstandard2.0" />
    <file src="bin\Release\netstandard2.0\NetSquare_Server.dll" target="lib\netstandard2.0" />

    <file src="bin\Release\net8.0-windows7.0\NetSquareCore.dll" target="lib\net8.0-windows7.0" />
    <file src="bin\Release\net8.0-windows7.0\NetSquare_Server.dll" target="lib\net8.0-windows7.0" />

    <file src="bin\Release\net48\NetSquareCore.dll" target="lib\net48" />
    <file src="bin\Release\net48\NetSquare_Server.dll" target="lib\net48" />

    <file src="NetSquareIcon.png" target="images" />
    <file src="README.md" target="" />
  </files>
</package>
